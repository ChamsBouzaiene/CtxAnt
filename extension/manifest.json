{
  "manifest_version": 3,
  "name": "CtxAnt — Text your browser anything",
  "short_name": "CtxAnt",
  "version": "1.0.0",
  "author": "Bouzaiene Chamseddine",
  "description": "Drive your real Chrome from Telegram through the CtxAnt Mac app. Local pairing, user-triggered browser automation, no hosted browser sandbox.",

  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "storage",
    "alarms"
  ],

  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "icons": {
    "16":  "icons/icon-16.png",
    "32":  "icons/icon-32.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "CtxAnt",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  }
}
