# ── AI Provider ───────────────────────────────────────────────
# "grok" uses your xAI tokens (cheaper). "claude" uses Anthropic.
AI_PROVIDER=grok

# Anthropic API key (only needed if AI_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-...

# xAI / Grok API key (only needed if AI_PROVIDER=grok)
XAI_API_KEY=xai-...
XAI_MODEL=grok-4-1-fast-reasoning

# ── Telegram ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=...
# Your Telegram user ID (get it from @userinfobot). Comma-separated for multiple users.
TELEGRAM_ALLOWED_USERS=123456789

# ── WebSocket bridge ───────────────────────────────────────────
# Must match WS_SECRET in extension/background.js
WS_SECRET=change-me-to-something-random
WS_PORT=8765

# Chrome extension identity (required for strict localhost pairing).
# Set CHROME_EXTENSION_ID to the published Web Store extension ID.
# Optionally add comma-separated unpacked/dev IDs in CHROME_EXTENSION_DEV_IDS.
CHROME_EXTENSION_ID=
CHROME_EXTENSION_DEV_IDS=
# Dev-only escape hatch for unpacked testing before you know the extension ID.
CHROME_EXTENSION_ALLOW_ANY_DEV_ORIGIN=1

# Optional: Chrome Web Store listing URL used in production onboarding copy.
CHROME_WEB_STORE_URL=
